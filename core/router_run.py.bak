from core.graph_v5 import build_execution_dag
from core.graph_clean import clean_graph
from core.executor import resolve_and_run


class GraphRunner:
    def __init__(self):
        g = build_execution_dag()
        self.graph = clean_graph(g)
g = rank_graph(g)
g = rank_graph(g)
g = rank_graph(g)

    def run(self, start):
        visited = set()
        result = []

        def dfs(node):
            if node in visited:
                return
            visited.add(node)

            out = resolve_and_run(node)
            result.append((node, out))

            for nxt in self.graph.get(node, []):
                dfs(nxt)

        dfs(start)
        return result


if __name__ == "__main__":
    r = GraphRunner()
    print(r.run("./main.py"))
